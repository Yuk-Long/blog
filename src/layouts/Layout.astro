---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <style is:global>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background-color: #fafaf8;
        color: #2c2c2c;
        font-family: Georgia, 'Noto Serif SC', 'Source Han Serif SC', '思源宋体', serif;
        line-height: 1.85;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* ====== 导航栏 ====== */
      header {
        border-bottom: 1px solid #e8e8e4;
        padding: 0 24px;
      }

      nav {
        max-width: 680px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 56px;
      }

      .nav-brand {
        font-size: 18px;
        font-weight: 700;
        color: #2c2c2c;
        text-decoration: none;
      }

      .nav-brand:hover {
        text-decoration: none;
      }

      .nav-links {
        display: flex;
        gap: 24px;
        list-style: none;
      }

      .nav-links a {
        font-size: 15px;
        color: #666;
        text-decoration: none;
        transition: color 0.2s;
      }

      .nav-links a:hover {
        color: #2c2c2c;
        text-decoration: none;
      }

      /* ====== 主内容区 ====== */
      .container {
        max-width: 680px;
        margin: 0 auto;
        padding: 48px 24px;
        min-height: calc(100vh - 56px - 80px);
      }

      /* ====== 页脚 ====== */
      footer {
        border-top: 1px solid #e8e8e4;
        padding: 24px;
        text-align: center;
        font-size: 13px;
        color: #999;
        line-height: 1.8;
      }

      footer a {
        color: #666;
        text-decoration: none;
      }

      footer a:hover {
        color: #2c2c2c;
      }

      /* ====== 链接 ====== */
      a {
        color: #2c2c2c;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      /* ====== 代码块 ====== */
      pre {
        background-color: #f4f4f4;
        border-radius: 6px;
        padding: 16px 20px;
        overflow-x: auto;
        font-size: 14px;
        line-height: 1.6;
        margin: 24px 0;
      }

      pre code {
        background: none;
        padding: 0;
        font-size: 14px;
      }

      code {
        font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', Consolas, monospace;
        font-size: 14px;
      }

      :not(pre) > code {
        background-color: #f0f0f0;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.9em;
      }

      /* ====== 文章内容排版 ====== */
      article h1 {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 12px;
        line-height: 1.4;
        letter-spacing: -0.01em;
      }

      article h2 {
        font-size: 22px;
        font-weight: 700;
        margin-top: 40px;
        margin-bottom: 14px;
        letter-spacing: -0.01em;
      }

      article h3 {
        font-size: 18px;
        font-weight: 700;
        margin-top: 32px;
        margin-bottom: 10px;
      }

      article p {
        margin-bottom: 18px;
        line-height: 1.85;
      }

      article ul,
      article ol {
        margin-bottom: 18px;
        padding-left: 28px;
      }

      article li {
        margin-bottom: 8px;
        line-height: 1.75;
      }

      article blockquote {
        border-left: 3px solid #d0d0d0;
        padding-left: 18px;
        color: #666;
        margin: 24px 0;
        font-style: italic;
      }

      article img {
        max-width: 100%;
        border-radius: 6px;
        margin: 24px 0;
      }

      article hr {
        border: none;
        border-top: 1px solid #e0e0e0;
        margin: 40px 0;
      }

      article a {
        color: #1a6eb5;
        text-decoration: underline;
      }

      article a:hover {
        color: #0d4f8a;
      }

      /* ====== 首页文章列表 ====== */
      .post-list {
        list-style: none;
        padding: 0;
      }

      .post-item {
        margin-bottom: 40px;
        padding-bottom: 40px;
        border-bottom: 1px solid #eee;
      }

      .post-item:last-child {
        border-bottom: none;
      }

      .post-item h2 {
        font-size: 20px;
        font-weight: 700;
        margin: 0 0 6px 0;
        line-height: 1.4;
      }

      .post-item h2 a {
        color: #2c2c2c;
        text-decoration: none;
      }

      .post-item h2 a:hover {
        color: #1a6eb5;
        text-decoration: none;
      }

      .post-meta {
        font-size: 13px;
        color: #999;
        margin-bottom: 10px;
      }

      .post-excerpt {
        font-size: 15px;
        color: #555;
        line-height: 1.75;
      }

      /* ====== 文章详情页 meta ====== */
      .article-meta {
        font-size: 14px;
        color: #999;
        margin-bottom: 36px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px 16px;
      }

      .article-meta span {
        white-space: nowrap;
      }

      /* ====== 标签 ====== */
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 36px;
      }

      .tag {
        display: inline-block;
        background: #eee;
        color: #666;
        font-size: 12px;
        padding: 3px 10px;
        border-radius: 12px;
        text-decoration: none;
      }

      .tag:hover {
        background: #ddd;
        text-decoration: none;
      }

      /* ====== 关于页面 ====== */
      .about-page h1 {
        font-size: 24px;
        margin-bottom: 20px;
      }

      .about-page p {
        margin-bottom: 16px;
        line-height: 1.85;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a class="nav-brand" href="/">我的博客</a>
        <ul class="nav-links">
          <li><a href="/">首页</a></li>
          <li><a href="/about/">关于</a></li>
        </ul>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} 我的博客 · 由 <a href="https://astro.build" target="_blank">Astro</a> 驱动</p>
      <p>联系我：<a href="mailto:hello@example.com">hello@example.com</a></p>
    </footer>
  </body>
</html>